   "source": [
    "# CELL 10-03: Attach mean SRS to episodes\n",
    "# Join pairs_srs on support_pair_ids → compute mean SRS per episode\n",
    "t0 = cell_start('10-03', 'Attach mean SRS to episodes')\n",
    "\n",
    "# Build pair_id → srs mapping\n",
    "# pairs_srs must contain 'pair_id' and 'srs' columns\n",
    "if 'pair_id' not in pairs_srs.columns:\n",
    "    # Fall back to index if pair_id not a column\n",
    "    pairs_srs = pairs_srs.reset_index().rename(columns={'index': 'pair_id'})\n",
    "\n",
    "pair_srs_map = pairs_srs.set_index('pair_id')['srs'].to_dict()\n",
    "print(f'pair_srs_map: {len(pair_srs_map)} entries')\n",
    "print(f'SRS range: [{min(pair_srs_map.values()):.4f}, {max(pair_srs_map.values()):.4f}]')\n",
    "\n",
    "def compute_episode_srs(support_pair_ids, pair_srs_map):\n",
    "    \"\"\"Compute mean SRS over support pairs for an episode.\"\"\"\n",
    "    scores = [pair_srs_map.get(pid, 0.0) for pid in support_pair_ids]\n",
    "    return float(np.mean(scores)) if scores else 0.0\n",
    "\n",
    "def attach_srs_to_episodes(episodes_df, pair_srs_map):\n",
    "    \"\"\"Add 'episode_srs' column to episodes DataFrame.\"\"\"\n",
    "    df = episodes_df.copy()\n",
    "    # support_pair_ids column may be a list or stringified list\n",
    "    if df['support_pair_ids'].dtype == object:\n",
    "        try:\n",
    "            sample = df['support_pair_ids'].iloc[0]\n",
    "            if isinstance(sample, str):\n",
    "                import ast\n",
    "                df['support_pair_ids'] = df['support_pair_ids'].apply(ast.literal_eval)\n",
    "        except Exception:\n",
    "            pass\n",
    "    df['episode_srs'] = df['support_pair_ids'].apply(\n",
    "        lambda pids: compute_episode_srs(pids, pair_srs_map)\n",
    "    )\n",
    "    return df\n",
    "\n",
    "episodes_train = attach_srs_to_episodes(episodes_train, pair_srs_map)\n",
    "episodes_val   = attach_srs_to_episodes(episodes_val,   pair_srs_map)\n",
    "episodes_test  = attach_srs_to_episodes(episodes_test,  pair_srs_map)\n",
    "\n",
    "print(f'Train episode_srs — mean={episodes_train[\"episode_srs\"].mean():.4f}  '\n",
    "      f'std={episodes_train[\"episode_srs\"].std():.4f}  '\n",
    "      f'min={episodes_train[\"episode_srs\"].min():.4f}  '\n",
    "      f'max={episodes_train[\"episode_srs\"].max():.4f}')\n",
