    "# CELL 10-07: Evaluation metrics\n",
    "t0 = cell_start('10-07', 'Evaluation metrics')\n",
    "\n",
    "def ndcg_at_k(ranked_items, true_item, k=10):\n",
    "    for i, item in enumerate(ranked_items[:k]):\n",
    "        if item == true_item:\n",
    "            return 1.0 / math.log2(i + 2)\n",
    "    return 0.0\n",
    "\n",
    "\n",
    "def compute_metrics(logits, labels):\n",
    "    \"\"\"\n",
    "    Compute HR@1, HR@5, HR@10, NDCG@10, MRR for a batch.\n",
    "    logits : (B, N_ITEMS) tensor\n",
    "    labels : (B,) tensor of true item ids\n",
    "    Returns dict of mean metric values.\n",
    "    \"\"\"\n",
    "    ranked = torch.argsort(logits, dim=1, descending=True).cpu().numpy()\n",
    "    labels_np = labels.cpu().numpy()\n",
    "\n",
    "    hr1_list, hr5_list, hr10_list, ndcg10_list, mrr_list = [], [], [], [], []\n",
    "\n",
    "    for i, true_item in enumerate(labels_np):\n",
    "        top_items = ranked[i]\n",
    "        hr1_list.append(1.0 if true_item in top_items[:1]  else 0.0)\n",
    "        hr5_list.append(1.0 if true_item in top_items[:5]  else 0.0)\n",
    "        hr10_list.append(1.0 if true_item in top_items[:10] else 0.0)\n",
    "        ndcg10_list.append(ndcg_at_k(top_items, true_item, k=10))\n",
    "        # MRR\n",
    "        rank = np.where(top_items == true_item)[0]\n",
    "        mrr_list.append(1.0 / (rank[0] + 1) if len(rank) > 0 else 0.0)\n",
    "\n",
    "    return {\n",
    "        'hr1':    float(np.mean(hr1_list)),\n",
    "        'hr5':    float(np.mean(hr5_list)),\n",
    "        'hr10':   float(np.mean(hr10_list)),\n",
    "        'ndcg10': float(np.mean(ndcg10_list)),\n",
    "        'mrr':    float(np.mean(mrr_list)),\n",
    "    }\n",
    "\n",
    "print('compute_metrics and ndcg_at_k defined')\n",
    "cell_end('10-07', t0)"
   ]
  },
