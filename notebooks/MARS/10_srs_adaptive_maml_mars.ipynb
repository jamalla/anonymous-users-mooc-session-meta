    "# CELL 10-08: Episode collation (pad_sequences, get_episode_data with srs field)\n",
    "t0 = cell_start('10-08', 'Episode collation helpers')\n",
    "\n",
    "def pad_sequences(seqs, pad_value=0):\n",
    "    \"\"\"\n",
    "    Pad a list of 1-D integer sequences to the same length.\n",
    "    Returns (padded_tensor, lengths_tensor) on DEVICE.\n",
    "    \"\"\"\n",
    "    lengths = torch.tensor([len(s) for s in seqs], dtype=torch.long)\n",
    "    max_len = int(lengths.max().item())\n",
    "    padded  = torch.zeros(len(seqs), max_len, dtype=torch.long)\n",
    "    for i, s in enumerate(seqs):\n",
    "        padded[i, :len(s)] = torch.tensor(s, dtype=torch.long)\n",
    "    return padded.to(DEVICE), lengths.to(DEVICE)\n",
    "\n",
    "\n",
    "def get_episode_data(row, pairs_df):\n",
    "    \"\"\"\n",
    "    Build a task dict from an episode row and the pairs DataFrame.\n",
    "    Expects pairs_df to have columns: pair_id, prefix, target_id, srs\n",
    "    Returns dict with keys:\n",
    "        support_seqs, support_lengths, support_labels,\n",
    "        query_seqs,   query_lengths,   query_labels,\n",
    "        srs  (mean SRS of support pairs)\n",
    "    \"\"\"\n",
    "    support_ids = row['support_pair_ids']\n",
    "    query_ids   = row['query_pair_ids']\n",
    "\n",
    "    # Parse stringified lists if needed\n",
    "    if isinstance(support_ids, str):\n",
    "        import ast\n",
    "        support_ids = ast.literal_eval(support_ids)\n",
    "    if isinstance(query_ids, str):\n",
    "        import ast\n",
    "        query_ids = ast.literal_eval(query_ids)\n",
    "\n",
    "    support_pairs = pairs_df[pairs_df['pair_id'].isin(support_ids)]\n",
    "    query_pairs   = pairs_df[pairs_df['pair_id'].isin(query_ids)]\n",
    "\n",
    "    support_seqs, support_lengths = pad_sequences(support_pairs['prefix'].tolist())\n",
    "    support_labels = torch.tensor(support_pairs['label'].tolist(),\n",
    "                                  dtype=torch.long).to(DEVICE)\n",
    "\n",
    "    query_seqs, query_lengths = pad_sequences(query_pairs['prefix'].tolist())\n",
    "    query_labels = torch.tensor(query_pairs['label'].tolist(),\n",
    "                                dtype=torch.long).to(DEVICE)\n",
    "\n",
    "    # Mean SRS of support pairs\n",
    "    srs_val = row.get('episode_srs', 0.5)\n",
    "\n",
    "    return {\n",
    "        'support_seqs':    support_seqs,\n",
    "        'support_lengths': support_lengths,\n",
    "        'support_labels':  support_labels,\n",
    "        'query_seqs':      query_seqs,\n",
    "        'query_lengths':   query_lengths,\n",
    "        'query_labels':    query_labels,\n",
    "        'srs':             float(srs_val),\n",
    "    }\n",
    "\n",
    "print('pad_sequences and get_episode_data defined')\n",
    "cell_end('10-08', t0)"
   ]
