    "# Pre-index pairs_srs by pair_id for fast lookup\n",
    "if 'pair_id' not in pairs_srs.columns:\n",
    "    pairs_srs = pairs_srs.reset_index().rename(columns={'index': 'pair_id'})\n",
    "\n",
    "loss_history    = []\n",
    "val_hr10_history = []\n",
    "\n",
    "for iteration in range(1, N_ITER + 1):\n",
    "    meta_model.train()\n",
    "\n",
    "    # Sample a mini-batch of episodes\n",
    "    batch_rows = np.random.choice(train_rows, size=min(BATCH_SIZE, len(train_rows)),\n",
    "                                  replace=False)\n",
    "    batch_tasks = [get_episode_data(row, pairs_srs) for row in batch_rows]\n",
    "\n",
    "    loss_val = outer_step(meta_model, batch_tasks, meta_optimizer)\n",
    "    loss_history.append(loss_val)\n",
    "\n",
    "    # Validation\n",
    "    if iteration % VAL_EVERY == 0:\n",
    "        meta_model.train()  # keep train mode — inner loop needs cuDNN backward\n",
    "        val_hr10_vals = []\n",
    "\n",
    "        with torch.no_grad():\n",
    "            for row in val_rows:\n",
    "                task = get_episode_data(row, pairs_srs)\n",
    "                srs_i    = task['srs']\n",
    "                alpha_i, K_i = get_task_hyperparams(srs_i)\n",
    "                params   = {n: p.clone() for n, p in meta_model.named_parameters()}\n",
    "\n",
    "                # Inner loop adaptation (with grad for inner, no_grad for outer eval)\n",
    "                # Re-enable grad for inner loop\n",
    "                torch.set_grad_enabled(True)\n",
    "                params = {n: p.clone().requires_grad_(True)\n",
    "                          for n, p in meta_model.named_parameters()}\n",
    "                phi_i = srs_adaptive_inner_loop(\n",
